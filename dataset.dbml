Enum Role {
  ADMIN
  CUSTOMER
  RIDER
  RESTAURANT_OWNER
}

Table Users {
  id integer [primary key]
  name varchar
  email varchar [unique, not null]
  phone varchar
  password varchar [not null]
  role Role [not null]
  profile_image varchar
  created_at timestamp
}

Table UserAddresses {
  id integer [primary key]
  user_id integer [ref: > Users.id]
  label varchar
  address text
  street varchar
  apparment_name varchar
  city varchar
  postal_code varchar
  latitude decimal
  longitude decimal
}
//sublass of user
Table RiderProfiles {
  user_id integer [primary key, ref: - Users.id] 
  vehicle_type varchar
  vehicle_number varchar
  status boolean [default: false]
}
//belongs to owner(user)
Table Restaurants {
  id integer [primary key]
  owner_id integer [ref: - Users.id]
  name varchar
  description text
  phone varchar
  email varchar
  address text
  latitude decimal
  longitude decimal
  opening_time time
  closing_time time
  //delivery_fee integer //should be variable
  minimum_order integer
  status boolean
}

Table Categories {
  id integer [primary key]
  category_name varchar
  category_img varchar
}

Table MenuItems {
  id integer [primary key]
  restaurant_id integer [ref: > Restaurants.id]
  category_id integer [ref: > Categories.id]
  item_name varchar
  description text
  price integer
  item_img varchar
  stock integer
  is_available boolean
}

Table Cart {
  id integer [primary key]
  user_id integer [ref: > Users.id]
  created_at timestamp
}

Table CartItems {
  id integer [primary key]
  cart_id integer [ref: > Cart.id]
  menu_item_id integer [ref: > MenuItems.id]
  quantity integer
}

Table Orders {
  id integer [primary key]
  user_id integer [ref: > Users.id]
  restaurant_id integer [ref: > Restaurants.id]
  address_id integer [ref: - Addresses.id]
  coupons_id integer [ref: - Coupons.id]
  total_amount integer
  delivery_fee integer
  discount integer
  payment_method varchar
  payment_status varchar
  order_status varchar
  created_at timestamp
}

Table OrderItems {
  id integer [primary key]
  order_id integer [ref: > Orders.id]
  menu_item_id integer [ref: > MenuItems.id]
  quantity integer
  unit_price integer
  subtotal integer
}

Table Payments {
  id integer [primary key]
  order_id integer [ref: - Orders.id]
  transaction_id varchar
  payment_method varchar
  amount integer
  status varchar
  paid_at timestamp
}



Table Deliveries {
  id integer [primary key]
  order_id integer [ref: - Orders.id]
  rider_id integer [ref: > DeliveryRiders.id]
  assigned_at timestamp
  delivered_at timestamp
  status varchar
}

Table Reviews {
  id integer [primary key]
  user_id integer [ref: > Users.id]
  restaurant_id integer [ref: > Restaurants.id]
  menu_item_id integer [ref: > MenuItems.id]
  rating integer
  comment text
  created_at timestamp
}

Table Coupons {
  id integer [primary key]
  code varchar
  discount_type varchar
  discount_value integer
  minimum_order integer
  expiry_date date
}

Table UserCoupons {
  id integer [primary key]
  user_id integer [ref: > Users.id]
  coupon_id integer [ref: > Coupons.id]
  used boolean
}

Table Notifications {
  id integer [primary key]
  user_id integer [ref: > Users.id]
  order_id integer [ref: > Orders.id]
  title varchar
  message text
  is_read boolean
  created_at timestamp
}